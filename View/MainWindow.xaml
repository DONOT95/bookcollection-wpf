<Window x:Class="BookCollection.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookCollection.View"
        mc:Ignorable="d"
        Title="My Private Book Collection" MinHeight="700" Height="700" MinWidth="900" Width="900">

    <Grid Margin="18">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Content -->
            <RowDefinition Height="*"/>
            <!-- Status -->
            <RowDefinition Height="Auto"/>
            <!-- Bottom Buttons -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Grid.ColumnSpan="2"
                   Text="{Binding AppHeading}"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,14"
                   HorizontalAlignment="Center"/>

        <!-- BOOK LIST -->
        <GroupBox Grid.Row="1"
                  Grid.RowSpan="3"
                  Header="Books"
                  Style="{StaticResource CardGroupBox}">

            <DataGrid ItemsSource="{Binding Books}"
                      SelectedItem="{Binding SelectedBook, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      SelectionUnit="FullRow"
                      SelectionMode="Single"
                      Background="Transparent"
                      BorderThickness="0"
                      RowStyle="{StaticResource DG_Row}"
                      CellStyle="{StaticResource DG_Cell}"
                      ColumnHeaderStyle="{StaticResource DG_Header}">
                
                <DataGrid.Columns>
                    <!-- Id (Numb) -->
                    <DataGridTextColumn Header="Id"
                            Binding="{Binding Id}"
                            Width="*"
                            MinWidth="50"
                            ElementStyle="{StaticResource DG_CellNumber}"/>

                    <!-- Title -->
                    <DataGridTextColumn Header="Title"
                            Binding="{Binding Title}"
                            Width="*"
                            MinWidth="60"
                            ElementStyle="{StaticResource DG_CellText}"/>

                    <!-- Author -->
                    <DataGridTextColumn Header="Author"
                            Binding="{Binding Author}"
                            Width="*"
                            MinWidth="65"
                            ElementStyle="{StaticResource DG_CellText}"/>

                    <!-- Genre -->
                    <DataGridTextColumn Header="Genre"
                            Binding="{Binding Genre}"
                            Width="*"
                            MinWidth="65"
                            ElementStyle="{StaticResource DG_CellText}"/>

                    <!-- Year (Numb) -->
                    <DataGridTextColumn Header="Year"
                            Binding="{Binding PublicationYear}"
                            Width="*"
                            MinWidth="50"
                            ElementStyle="{StaticResource DG_CellNumber}"/>

                </DataGrid.Columns>
            </DataGrid>

        </GroupBox>

        <!-- FORM + ACTIONS -->
        <GroupBox Grid.Column="1" Grid.Row="1" Header="Book"
                    Margin="18 0 0 10"
                    Style="{StaticResource CardGroupBox}">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Clear Button Row -->
                    <RowDefinition Height="Auto"/>
                    <!-- Form -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 🔄 CLEAR BUTTON -->
                <Button Grid.Row="0"
                        Content="Clear"
                        Command="{Binding ClearFormCommand}"
                        Style="{StaticResource ModernButton_Hover}"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,10"
                        />

                <!-- FORM -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- Lbl -->
                        <ColumnDefinition Width="80"/>
                        <!-- Input -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Text="Title:"
                               Grid.Row="0"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             MaxLength="{Binding MaxInputLength}"
                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- title COUNTER -->
                    <TextBlock Text="{Binding TitleCounter}"
                               Grid.Column="1"
                               Grid.Row="1"
                               Style="{StaticResource CounterTextStyle}"
                               Tag="{Binding TitleState}"
                               HorizontalAlignment="Right"
                              />

                    <!-- Author -->
                    <TextBlock Text="Author:"
                               Grid.Row="2"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             MaxLength="{Binding MaxInputLength}"
                             Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Author COUNTER -->
                    <TextBlock Text="{Binding AuthorCounter}"
                               Grid.Column="1"
                               Grid.Row="3"
                               Style="{StaticResource CounterTextStyle}"
                               Tag="{Binding AuthorState}"
                               HorizontalAlignment="Right"
                               />

                    <!-- Genre -->
                    <TextBlock Text="Genre:"
                               Grid.Row="4"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             MaxLength="{Binding MaxInputLength}"
                             Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Genre COUNTER -->
                    <TextBlock Text="{Binding GenreCounter}"
                               Grid.Column="1"
                               Grid.Row="5"
                               Style="{StaticResource CounterTextStyle}"
                               Tag="{Binding GenreState}"
                               HorizontalAlignment="Right"
                               />

                    <!-- Year -->
                    <TextBlock Text="Year:"
                               Grid.Row="6"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="6"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             MaxLength="{Binding MaxYearLength}"
                             Text="{Binding PublicationYear}"/>

                </Grid>
            </Grid>
        </GroupBox>

        <!-- ACTION BUTTONS -->
        <GroupBox Grid.Column="1" Grid.Row="2" Header="Actions"  Margin="18 0 0 10" Style="{StaticResource CardGroupBox}">
                <UniformGrid Columns="4">
                    
                    <Button Content="Create"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding CreateCommand}"/>

                    <Button Content="Modify"
                        Style="{StaticResource ModifyButtonStyle}"
                        Command="{Binding ModifyCommand}"/>

                    <Button Content="Delete"
                        Style="{StaticResource DeleteButtonStyle}"
                        Command="{Binding DeleteCommand}"/>

                    <Button Content="Filter"
                        Style="{StaticResource ModernButton_Hover}"
                        Command="{Binding FilterCommand}"/>

                </UniformGrid>
            </GroupBox>


        <!-- STATUS -->
        <GroupBox Grid.Row="3"
                  Grid.Column="1"
                  Header="Status"
                  Style="{StaticResource CardGroupBox}"
                  Margin="18 0 0 14">

            <TextBlock Text="{Binding NotifyMessage}"
                       Foreground="{StaticResource DangerHoverBrush}"
                       TextWrapping="Wrap"
                       FontSize="16"/>

        </GroupBox>

        <!-- Border Below status -->
        <Border Grid.Row="4"
                Grid.ColumnSpan="2"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,2,0,0"
                Padding="10"
        />  

        <!-- Actions bottom -->
        <Grid Grid.Row="4"
              Grid.ColumnSpan="2"
              Margin="0,14,0,0">    

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>


            <!-- DISPLAY ALL (links) -->
            <Button Grid.Column="0"
                    Content="Display All"
                    Style="{StaticResource ModernButton_Hover}"
                    Command="{Binding DisplayAllCommand}"
                    MinWidth="100"/>

            <!-- EXIT (rechts) -->
            <Button Grid.Column="2"
                    Content="Exit App"
                    Style="{StaticResource ModernButton_Hover}"
                    Command="{Binding ExitAppCommand}"
                    MinWidth="100"/>
        </Grid>

    </Grid>
</Window>
